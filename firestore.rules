rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper functions
    // ============================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function maxStringLength(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    // ============================================
    // Threads
    // ============================================
    match /threads/{threadId} {
      // 誰でも閲覧可能
      allow read: if true;
      // 認証済みユーザーのみ作成可能、タイトル文字数制限
      allow create: if isAuthenticated()
        && maxStringLength(request.resource.data.title, 200);
      // postCount, updatedAt の更新のみ許可（フィールド制限付き）
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postCount', 'updatedAt']);
      allow delete: if false;

      // Posts subcollection
      match /posts/{postId} {
        allow read: if true;
        allow create: if isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && maxStringLength(request.resource.data.body, 5000);
        allow update: if isOwner(resource.data.userId);
        allow delete: if isOwner(resource.data.userId);
      }
    }

    // ============================================
    // Users
    // ============================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;

      // Point history subcollection
      match /point_history/{historyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ============================================
    // Feedback
    // ============================================
    match /feedback/{feedbackId} {
      allow read: if false;
      allow create: if isAuthenticated()
        && maxStringLength(request.resource.data.content, 5000);
      allow update, delete: if false;
    }

    // ============================================
    // Translations cache
    // ============================================
    match /translations/{translationId} {
      allow read: if true;
      // 翻訳キャッシュは作成のみ許可（上書き防止）、フィールド検証付き
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['sourceText', 'targetLang', 'translatedText', 'createdAt'])
        && request.resource.data.sourceText is string
        && request.resource.data.translatedText is string
        && request.resource.data.sourceText.size() <= 5000
        && request.resource.data.translatedText.size() <= 10000;
      allow update, delete: if false;
    }
  }
}
