{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".output/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "server"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": ".output/server",
      "codebase": "nuxt-server",
      "runtime": "nodejs20"
    }
  ]
}
